# protonpass-to-bitwarden-sync -- environment configuration
#
# Copy this file to .env and edit the values, then export them before
# running the sync script:
#
#   cp .env.example .env
#   # edit .env
#   set -a; source .env; set +a
#   ./protonpass-to-bitwarden-sync.sh --dry-run
#
# All values are optional; the defaults shown here are what the script
# uses when the variable is unset.

# Path to the Proton Pass CLI binary (default: pass-cli)
PROTON_PASS_BIN=pass-cli

# Path to the Bitwarden CLI binary (default: bw)
BITWARDEN_BIN=bw

# Bitwarden server URL. When set, the script ensures `bw` is pointed at
# this server before authenticating (skips the call if already matched).
# Set to a self-hosted instance such as Vaultwarden to target it:
#   BW_SERVER=https://vaultwarden.example.com
# Comment this out (leave BW_SERVER unset) to use whatever `bw` is
# already configured against -- the script will not touch bw's config.
BW_SERVER=https://vault.bitwarden.com

# Dry-run mode: "true" previews what would be created without writing
# anything. Equivalent to passing --dry-run on the command line.
DRY_RUN=false

# Skip items whose name already matches a Bitwarden item. Equivalent to
# passing --skip-existing on the command line.
SKIP_EXISTING=false

# Also sync Proton Pass items that have been moved to Trash. By default only
# Active items are synced. Equivalent to --include-trashed.
INCLUDE_TRASHED=false

# Bitwarden session key printed by `bw unlock`. Required when the
# Bitwarden vault is locked (the script will detect this and tell you
# to set it). Get it with:
#   bw unlock
# then paste the exported value here. Leave commented to use the
# already-exported value from your shell environment.
#BW_SESSION="<paste-session-key-here>"
